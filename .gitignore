# Secrets — never commit
.env
.env.*

# OS junk
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Node
node_modules/
supabase/.temp/

# One-off scripts — never deploy to production
*.py
*.sh
*.ipynb
__pycache__/

# Repo-level tooling (allowed)
!scripts/
!scripts/*
!tools/
!tools/*
tools/__pycache__/

# Sensitive local auth snapshots — never commit
.stohler_auth_snapshot.json
us-counties.json.bak

# E2E test artifacts
tests/e2e/.test-state.json
tests/e2e/test-results/
tests/e2e/playwright-report/

# Attorney/draft documents — never commit
_drafts/
# Backup files — never deploy (general pattern)
*.bak.*

# Handoff files — folder is tracked (via README), session notes are not
handoffs/*
!handoffs/README.md

# Generated code-map artifacts — stored in Docs/ in Google Drive, not git
Docs/code-map.json
Docs/code-map.md
